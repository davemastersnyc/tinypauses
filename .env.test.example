NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Must match the app's admin allowlist check.
ADMIN_EMAIL=admin@example.com

# Dedicated test identities (never use production accounts).
E2E_TEST_USER_EMAIL=e2e-user@example.com
E2E_TEST_ADMIN_EMAIL=admin@example.com

# Optional overrides
E2E_BASE_URL=http://localhost:3000
E2E_EMAIL_DOMAIN=example.com
